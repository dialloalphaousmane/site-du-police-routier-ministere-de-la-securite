{% extends 'base.html.twig' %}

{% block title %}Liste des Infractions - Police Routière{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <h1>
                    <i class="bi bi-exclamation-triangle"></i> Infractions Routières
                </h1>
                {% if is_granted('ROLE_AGENT') %}
                    <a href="{{ path('app_infraction_new') }}" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Nouvelle Infraction
                    </a>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Cartes de statistiques -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Infractions</h5>
                    <h2>{{ infractions|length }}</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5 class="card-title">En Attente</h5>
                    <h2>{{ infractions|filter(i => i.statut == 'NON_PAYEE')|length }}</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5 class="card-title">Partiellement Payées</h5>
                    <h2>{{ infractions|filter(i => i.statut == 'PARTIELLEMENT_PAYEE')|length }}</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Payées</h5>
                    <h2>{{ infractions|filter(i => i.statut == 'PAYEE')|length }}</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Tableau des infractions -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-list"></i> Liste des Infractions
            </h5>
        </div>
        <div class="card-body">
            {% if infractions|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Référence</th>
                                <th>Code</th>
                                <th>Description</th>
                                <th>Montant</th>
                                <th>Conducteur</th>
                                <th>Contrôle</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for infraction in infractions %}
                                <tr>
                                    <td>
                                        <span class="badge bg-secondary">{{ infraction.reference }}</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-warning">{{ infraction.codeInfraction }}</span>
                                    </td>
                                    <td>
                                        {{ infraction.description|length > 50 ? infraction.description|slice(0, 50) ~ '...' : infraction.description }}
                                    </td>
                                    <td>
                                        <strong>{{ infraction.montantAmende|number_format(0, ',', ' ') }} GNF</strong>
                                    </td>
                                    <td>
                                        {{ infraction.controle.nomConducteur }} {{ infraction.controle.prenomConducteur }}
                                    </td>
                                    <td>
                                        <a href="{{ path('app_controle_show', {'id': infraction.controle.id}) }}" 
                                           class="text-decoration-none">
                                            <i class="bi bi-eye"></i> {{ infraction.controle.immatriculation }}
                                        </a>
                                    </td>
                                    <td>
                                        {% if infraction.statut == 'NON_PAYEE' %}
                                            <span class="badge bg-danger">Non Payée</span>
                                        {% elseif infraction.statut == 'PARTIELLEMENT_PAYEE' %}
                                            <span class="badge bg-warning">Partiellement Payée</span>
                                        {% elseif infraction.statut == 'PAYEE' %}
                                            <span class="badge bg-success">Payée</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="{{ path('app_infraction_show', {'id': infraction.id}) }}" 
                                               class="btn btn-sm btn-outline-primary" title="Voir">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            {% if is_granted('ROLE_AGENT') %}
                                                <a href="{{ path('app_infraction_edit', {'id': infraction.id}) }}" 
                                                   class="btn btn-sm btn-outline-warning" title="Modifier">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a href="{{ path('app_amende_new', {'infractionId': infraction.id}) }}" 
                                                   class="btn btn-sm btn-outline-success" title="Créer Amende">
                                                    <i class="bi bi-cash"></i>
                                                </a>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-4">
                    <i class="bi bi-inbox display-1 text-muted"></i>
                    <h4 class="mt-3">Aucune infraction trouvée</h4>
                    <p class="text-muted">
                        {% if is_granted('ROLE_AGENT') %}
                            Commencez par <a href="{{ path('app_controle_new') }}">créer un contrôle</a> puis ajoutez des infractions.
                        {% endif %}
                    </p>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
