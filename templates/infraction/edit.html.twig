{% extends 'base.html.twig' %}

{% block title %}Modifier Infraction - Police Routière{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="bi bi-pencil"></i> Modifier l'Infraction
                    </h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i>
                        Modification de l'infraction: <strong>{{ infraction.reference }}</strong>
                    </div>

                    {{ form_start(form) }}
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_label(form.controle) }}
                            {{ form_widget(form.controle, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.controle) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_label(form.codeInfraction) }}
                            {{ form_widget(form.codeInfraction, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.codeInfraction) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            {{ form_label(form.description) }}
                            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                            {{ form_errors(form.description) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            {{ form_label(form.montantAmende) }}
                            {{ form_widget(form.montantAmende, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.montantAmende) }}
                        </div>
                        <div class="col-md-4 mb-3">
                            {{ form_label(form.categorie) }}
                            {{ form_widget(form.categorie, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.categorie) }}
                        </div>
                        <div class="col-md-4 mb-3">
                            {{ form_label(form.statut) }}
                            {{ form_widget(form.statut, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.statut) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="d-flex justify-content-between">
                                <a href="{{ path('app_infraction_show', {'id': infraction.id}) }}" 
                                   class="btn btn-secondary">
                                    <i class="bi bi-arrow-left"></i> Annuler
                                </a>
                                <button type="submit" class="btn btn-warning">
                                    <i class="bi bi-check-circle"></i> Enregistrer les modifications
                                </button>
                            </div>
                        </div>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
