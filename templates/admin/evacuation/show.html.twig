{% extends 'base.html.twig' %}

{% block title %}Détails de l'Évacuation {{ evacuation.reference }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Évacuation {{ evacuation.reference }}</h1>
        <div class="btn-group">
            <a href="{{ path('app_admin_evacuation_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Retour à la liste
            </a>
            <a href="{{ path('app_admin_evacuation_edit', {'id': evacuation.id}) }}" class="btn btn-warning">
                <i class="fas fa-edit"></i> Modifier
            </a>
        </div>
    </div>

    <!-- Informations principales -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Informations de l'Évacuation</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Référence:</strong> {{ evacuation.reference }}</p>
                            <p><strong>Date d'évacuation:</strong> {{ evacuation.dateEvacuation|date('d/m/Y H:i') }}</p>
                            <p><strong>Type:</strong> 
                                <span class="badge badge-{{ 
                                    evacuation.typeEvacuation == 'AMBULANCE' ? 'primary' : 
                                    (evacuation.typeEvacuation == 'HELI' ? 'info' : 
                                    (evacuation.typeEvacuation == 'CAMION' ? 'warning' : 'secondary')) 
                                }}">
                                    {{ evacuation.typeEvacuation }}
                                </span>
                            </p>
                            <p><strong>Statut:</strong> 
                                <span class="badge badge-{{ 
                                    evacuation.status == 'EN_COURS' ? 'warning' : 
                                    (evacuation.status == 'TERMINE' ? 'success' : 'secondary') 
                                }}">
                                    {{ evacuation.status }}
                                </span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Urgence:</strong> 
                                <span class="badge badge-{{ 
                                    evacuation.urgence == 'HAUTE' ? 'danger' : 
                                    (evacuation.urgence == 'MOYENNE' ? 'warning' : 'info') 
                                }}">
                                    {{ evacuation.urgence }}
                                </span>
                            </p>
                            <p><strong>Hôpital destination:</strong> {{ evacuation.hopitalDestination }}</p>
                            <p><strong>Région:</strong> {{ evacuation.region ? evacuation.region.libelle : 'Non définie' }}</p>
                            <p><strong>Brigade:</strong> {{ evacuation.brigade ? evacuation.brigade.libelle : 'Non définie' }}</p>
                        </div>
                    </div>
                    
                    {% if evacuation.dateArrivee %}
                    <div class="row mt-3">
                        <div class="col-md-6">
                            <p><strong>Date d'arrivée:</strong> {{ evacuation.dateArrivee|date('d/m/Y H:i') }}</p>
                        </div>
                        <div class="col-md-6">
                            {% set duration = evacuation.dateEvacuation.diff(evacuation.dateArrivee) %}
                            <p><strong>Durée:</strong> {{ duration.format('%H') }}h {{ duration.format('%i') }}min</p>
                        </div>
                    </div>
                    {% endif %}
                    
                    {% if evacuation.observations %}
                    <div class="mt-3">
                        <p><strong>Observations:</strong></p>
                        <p class="text-muted">{{ evacuation.observations|nl2br }}</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Informations Opérateur</h6>
                </div>
                <div class="card-body">
                    <div class="text-center">
                        <p class="mb-0"><small class="text-gray-500">Opérateur</small></p>
                        <p class="font-weight-bold">{{ evacuation.createdBy ? evacuation.createdBy.nom ~ ' ' ~ evacuation.createdBy.prenom : 'Non défini' }}</p>
                    </div>
                </div>
            </div>

            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Actions</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        {% if evacuation.status == 'EN_COURS' %}
                        <form method="post" action="{{ path('app_admin_evacuation_complete', {'id': evacuation.id}) }}" 
                              onsubmit="return confirm('Marquer cette évacuation comme terminée ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('complete' ~ evacuation.id) }}">
                            <button type="submit" class="btn btn-success btn-sm">
                                <i class="fas fa-check"></i> Marquer comme terminée
                            </button>
                        </form>
                        <form method="post" action="{{ path('app_admin_evacuation_cancel', {'id': evacuation.id}) }}" 
                              onsubmit="return confirm('Annuler cette évacuation ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ evacuation.id) }}">
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="fas fa-times"></i> Annuler l'évacuation
                            </button>
                        </form>
                        {% endif %}
                        <a href="{{ path('app_admin_evacuation_edit', {'id': evacuation.id}) }}" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                    </div>
                </div>
            </div>

            <!-- Statistiques -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Statistiques</h6>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6">
                            <div class="h4 mb-0 font-weight-bold text-primary">{{ evacuation.nbVictimesEvacuees }}</div>
                            <div class="small text-gray-500">Victimes évacuées</div>
                        </div>
                        <div class="col-6">
                            <div class="h4 mb-0 font-weight-bold text-info">{{ evacuation.distanceKm }}</div>
                            <div class="small text-gray-500">Distance (km)</div>
                        </div>
                    </div>
                    {% if evacuation.dureeMinutes > 0 %}
                    <hr>
                    <div class="text-center">
                        <div class="h4 mb-0 font-weight-bold text-warning">{{ evacuation.dureeMinutes }}</div>
                        <div class="small text-gray-500">Durée (min)</div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Accident associé -->
    {% if evacuation.accident %}
    <div class="row">
        <div class="col-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Accident Associé</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <p><strong>Référence:</strong> {{ evacuation.accident.reference }}</p>
                            <p><strong>Date:</strong> {{ evacuation.accident.dateAccident|date('d/m/Y H:i') }}</p>
                        </div>
                        <div class="col-md-3">
                            <p><strong>Localisation:</strong> {{ evacuation.accident.localisation }}</p>
                            <p><strong>Gravité:</strong> 
                                <span class="badge badge-{{ 
                                    evacuation.accident.gravite == 'MORTEL' ? 'danger' : 
                                    (evacuation.accident.gravite == 'GRAVE' ? 'warning' : 'info') 
                                }}">
                                    {{ evacuation.accident.gravite }}
                                </span>
                            </p>
                        </div>
                        <div class="col-md-3">
                            <p><strong>Victimes:</strong> {{ evacuation.accident.victims|length }}</p>
                            <p><strong>Véhicules:</strong> {{ evacuation.accident.vehicles|length }}</p>
                        </div>
                        <div class="col-md-3">
                            <p><strong>Déclarant:</strong> {{ evacuation.accident.createdBy ? evacuation.accident.createdBy.nom ~ ' ' ~ evacuation.accident.createdBy.prenom : '' }}</p>
                            <a href="{{ path('app_admin_accident_show', {'id': evacuation.accident.id}) }}" 
                               class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye"></i> Voir l'accident
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    <!-- Timeline de l'évacuation -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Timeline de l'Évacuation</h6>
                </div>
                <div class="card-body">
                    <div class="timeline">
                        <div class="timeline-item">
                            <div class="timeline-marker bg-primary">
                                <i class="fas fa-play"></i>
                            </div>
                            <div class="timeline-content">
                                <h6 class="mb-1">Début de l'évacuation</h6>
                                <p class="text-muted">{{ evacuation.dateEvacuation|date('d/m/Y H:i') }}</p>
                                <p>Type: {{ evacuation.typeEvacuation }}, Urgence: {{ evacuation.urgence }}</p>
                            </div>
                        </div>
                        
                        {% if evacuation.dateArrivee %}
                        <div class="timeline-item">
                            <div class="timeline-marker bg-success">
                                <i class="fas fa-check"></i>
                            </div>
                            <div class="timeline-content">
                                <h6 class="mb-1">Arrivée à l'hôpital</h6>
                                <p class="text-muted">{{ evacuation.dateArrivee|date('d/m/Y H:i') }}</p>
                                <p>Hôpital: {{ evacuation.hopitalDestination }}</p>
                                {% set duration = evacuation.dateEvacuation.diff(evacuation.dateArrivee) %}
                                <p>Durée: {{ duration.format('%H') }}h {{ duration.format('%i') }}min</p>
                            </div>
                        </div>
                        {% endif %}
                        
                        <div class="timeline-item">
                            <div class="timeline-marker bg-{{ 
                                evacuation.status == 'TERMINE' ? 'success' : 
                                (evacuation.status == 'ANNULE' ? 'danger' : 'warning') 
                            }}">
                                <i class="fas fa-{{ 
                                    evacuation.status == 'TERMINE' ? 'check' : 
                                    (evacuation.status == 'ANNULE' ? 'times' : 'clock') 
                                }}"></i>
                            </div>
                            <div class="timeline-content">
                                <h6 class="mb-1">Statut actuel</h6>
                                <p class="text-muted">{{ evacuation.status }}</p>
                                {% if evacuation.status == 'ANNULE' %}
                                <p class="text-danger">L'évacuation a été annulée</p>
                                {% elseif evacuation.status == 'TERMINE' %}
                                <p class="text-success">L'évacuation s'est terminée avec succès</p>
                                {% else %}
                                <p class="text-warning">L'évacuation est toujours en cours</p>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.timeline {
    position: relative;
    padding-left: 40px;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 15px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #e3e6f0;
}

.timeline-item {
    position: relative;
    margin-bottom: 30px;
}

.timeline-marker {
    position: absolute;
    left: -40px;
    top: 0;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 12px;
}

.timeline-content {
    background: #f8f9fc;
    padding: 15px;
    border-radius: 8px;
    border-left: 4px solid #e3e6f0;
}
</style>
{% endblock %}
