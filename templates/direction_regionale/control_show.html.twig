{% extends 'base.html.twig' %}

{% block title %}Contrôle #{{ control.id }} - {{ region.libelle }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1 class="h4 mb-0"><i class="bi bi-eye me-2"></i>Détails du Contrôle</h1>
            <div class="text-muted">Région : {{ region.libelle }}</div>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('app_direction_regionale_controls') }}" class="btn btn-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Retour
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="text-muted small">Date</div>
                    <div class="fw-bold">{{ control.dateControle ? control.dateControle|date('d/m/Y H:i') : '-' }}</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Brigade</div>
                    <div class="fw-bold">{{ control.brigade ? control.brigade.code : '-' }}</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Lieu</div>
                    <div class="fw-bold">{{ control.lieuControle }}</div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">Immatriculation</div>
                    <div class="fw-bold">{{ control.immatriculation }}</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Marque véhicule</div>
                    <div class="fw-bold">{{ control.marqueVehicule }}</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Statut</div>
                    <div class="fw-bold">{{ control.statut }}</div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">Conducteur</div>
                    <div class="fw-bold">{{ control.prenomConducteur }} {{ control.nomConducteur }}</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">N° Conducteur</div>
                    <div class="fw-bold">{{ control.noConducteur }}</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Agent</div>
                    <div class="fw-bold">{{ control.agent ? control.agent.nom ~ ' ' ~ control.agent.prenom : '-' }}</div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">Observation</div>
                    <div class="fw-bold">{{ control.observation ?: '-' }}</div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
