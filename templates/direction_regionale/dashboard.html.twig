{% extends 'base.html.twig' %}

{% block title %}Direction Régionale: {{ region.libelle }}{% endblock %}

{% block body %}
<nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
    <div class="container-fluid">
        <a class="navbar-brand" href="{{ path('app_direction_regionale_dashboard') }}">
            <i class="bi bi-shield-check me-2"></i>
            Police Routière Guinée - Direction Régionale
        </a>
        <div class="navbar-nav ms-auto">
            <div class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle me-1"></i>
                    {{ app.user.email }}
                </a>
                <ul class="dropdown-menu">
                    <li>
                        <form method="post" action="{{ path('app_logout') }}">
                            <button type="submit" class="dropdown-item">
                                <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</nav>

<div class="container-fluid" style="padding-top: 70px;">
    <div class="row">
        <nav class="col-md-3 col-lg-2 d-md-block bg-light sidebar">
            <div class="position-sticky pt-3">
                <div class="px-3 mb-3">
                    <div class="text-muted small">Région</div>
                    <div class="fw-bold">{{ region.libelle }}</div>
                </div>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link active" href="{{ path('app_direction_regionale_dashboard') }}">
                            <i class="bi bi-speedometer2 me-2"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_direction_regionale_brigades') }}">
                            <i class="bi bi-shield me-2"></i>Brigades
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_direction_regionale_controls') }}">
                            <i class="bi bi-list-check me-2"></i>Contrôles
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_direction_regionale_infractions') }}">
                            <i class="bi bi-exclamation-triangle me-2"></i>Infractions
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_direction_regionale_amendes') }}">
                            <i class="bi bi-cash-coin me-2"></i>Amendes
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <div>
                    <h1 class="h2 mb-0">Dashboard Direction Régionale</h1>
                    <div class="text-muted">{{ region.libelle }}</div>
                </div>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <div class="btn-group me-2">
                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_direction_regionale_controls') }}">
                            <i class="bi bi-clipboard-check me-1"></i>Contrôles
                        </a>
                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_direction_regionale_amendes') }}">
                            <i class="bi bi-cash-coin me-1"></i>Amendes
                        </a>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-xl-2 col-md-4 mb-3">
                    <div class="card border-info h-100">
                        <div class="card-body text-center">
                            <div class="h3 text-info mb-0">{{ stats.brigades_count }}</div>
                            <small class="text-muted">Brigades</small>
                        </div>
                    </div>
                </div>
                <div class="col-xl-2 col-md-4 mb-3">
                    <div class="card border-success h-100">
                        <div class="card-body text-center">
                            <div class="h3 text-success mb-0">{{ stats.controls_count }}</div>
                            <small class="text-muted">Contrôles</small>
                        </div>
                    </div>
                </div>
                <div class="col-xl-2 col-md-4 mb-3">
                    <div class="card border-warning h-100">
                        <div class="card-body text-center">
                            <div class="h3 text-warning mb-0">{{ stats.infractions_count }}</div>
                            <small class="text-muted">Infractions</small>
                        </div>
                    </div>
                </div>
                <div class="col-xl-2 col-md-4 mb-3">
                    <div class="card border-dark h-100">
                        <div class="card-body text-center">
                            <div class="h3 text-dark mb-0">{{ stats.amendes_count }}</div>
                            <small class="text-muted">Amendes (total)</small>
                        </div>
                    </div>
                </div>
                <div class="col-xl-2 col-md-4 mb-3">
                    <div class="card border-danger h-100">
                        <div class="card-body text-center">
                            <div class="h3 text-danger mb-0">{{ stats.amendes_pending }}</div>
                            <small class="text-muted">En attente</small>
                        </div>
                    </div>
                </div>
                <div class="col-xl-2 col-md-4 mb-3">
                    <div class="card border-primary h-100">
                        <div class="card-body text-center">
                            <div class="h3 text-primary mb-0">{{ stats.amendes_paid }}</div>
                            <small class="text-muted">Payées</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-header d-flex align-items-center justify-content-between">
                            <h6 class="card-title mb-0">10 derniers contrôles de la région</h6>
                            <a href="{{ path('app_direction_regionale_controls') }}" class="btn btn-sm btn-outline-secondary">Voir tout</a>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Brigade</th>
                                        <th>Lieu</th>
                                        <th>Immatriculation</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for control in recent_controls %}
                                        <tr>
                                            <td><small>{{ control.dateControle|date('d/m H:i') }}</small></td>
                                            <td>{{ control.brigade.code }}</td>
                                            <td>{{ control.lieuControle }}</td>
                                            <td><strong>{{ control.immatriculation }}</strong></td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="4" class="text-center py-3 text-muted">Aucun contrôle récent</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}
