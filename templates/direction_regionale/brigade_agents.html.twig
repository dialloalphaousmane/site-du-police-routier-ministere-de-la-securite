{% extends 'base.html.twig' %}

{% block title %}Agents - Brigade {{ brigade.code }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1 class="h4 mb-0"><i class="bi bi-people me-2"></i>Agents - Brigade {{ brigade.code }}</h1>
            <div class="text-muted">{{ region.libelle }}</div>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('app_direction_regionale_brigade_show', {id: brigade.id}) }}" class="btn btn-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Retour
            </a>
        </div>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Matricule</th>
                        <th>Nom</th>
                        <th>Grade</th>
                        <th>Région</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for agent in agents %}
                        <tr>
                            <td><span class="badge bg-dark">{{ agent.matricule }}</span></td>
                            <td><strong>{{ agent.nom }} {{ agent.prenom }}</strong></td>
                            <td>{{ agent.grade }}</td>
                            <td>{{ agent.region ? agent.region.libelle : '-' }}</td>
                            <td>
                                {% if agent.actif %}
                                    <span class="badge bg-success">Actif</span>
                                {% else %}
                                    <span class="badge bg-secondary">Inactif</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Aucun agent</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
