{% extends 'base.html.twig' %}

{% block title %}Contrôles - {{ region.libelle }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1><i class="bi bi-list-check me-2"></i>Contrôles - {{ region.libelle }}</h1>
        </div>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Brigade</th>
                        <th>Lieu</th>
                        <th>Véhicule</th>
                        <th>Conducteur</th>
                        <th>Agent</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% if controls|length > 0 %}
                        {% for control in controls %}
                            <tr>
                                <td>
                                    <small>{{ control.dateControle|date('d/m/Y H:i') }}</small>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">{{ control.brigade.code }}</span>
                                </td>
                                <td>{{ control.lieuControle }}</td>
                                <td>
                                    {{ control.marqueVehicule }}
                                    <br>
                                    <strong>{{ control.immatriculation }}</strong>
                                </td>
                                <td>
                                    {{ control.prenomConducteur }} {{ control.nomConducteur }}
                                    <br>
                                    <small class="text-muted">N°: {{ control.noConducteur }}</small>
                                </td>
                                <td>
                                    {% if control.agent %}
                                        <span class="badge bg-dark">{{ control.agent.matricule }}</span>
                                        {{ control.agent.nom }} {{ control.agent.prenom }}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <a href="{{ path('app_direction_regionale_control_show', {id: control.id}) }}" class="btn btn-sm btn-info" title="Voir">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Aucun contrôle</td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    {% if pagination.total_pages > 1 %}
        <nav aria-label="Pagination" class="mt-3">
            <ul class="pagination justify-content-center">
                {% if pagination.current_page > 1 %}
                    <li class="page-item">
                        <a class="page-link" href="?page={{ pagination.current_page - 1 }}">Précédent</a>
                    </li>
                {% endif %}
                {% for i in 1..pagination.total_pages %}
                    <li class="page-item {% if i == pagination.current_page %}active{% endif %}">
                        <a class="page-link" href="?page={{ i }}">{{ i }}</a>
                    </li>
                {% endfor %}
                {% if pagination.current_page < pagination.total_pages %}
                    <li class="page-item">
                        <a class="page-link" href="?page={{ pagination.current_page + 1 }}">Suivant</a>
                    </li>
                {% endif %}
            </ul>
        </nav>
    {% endif %}

    <div class="mt-3">
        <a href="{{ path('app_dashboard_direction_regionale') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Retour
        </a>
    </div>
</div>
{% endblock %}
