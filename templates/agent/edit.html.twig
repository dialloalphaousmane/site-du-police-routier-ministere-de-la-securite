{% extends 'base.html.twig' %}

{% block title %}Modifier l'Agent{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Modifier l'Agent</h1>
        <div>
            <a href="{{ path('app_agent_show', {'id': agent.id}) }}" class="btn btn-info">
                <i class="fas fa-eye"></i> Voir
            </a>
            <a href="{{ path('app_agent_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Retour
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Modifier les informations de l'Agent</h5>
        </div>
        <div class="card-body">
            {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
            
            <div class="row">
                <div class="col-md-6">
                    {{ form_row(form.nom) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.prenom) }}
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    {{ form_row(form.grade) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.dateEmbauche) }}
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    {{ form_row(form.region) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.brigade) }}
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    {{ form_row(form.email) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.telephone) }}
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    {{ form_row(form.adresse) }}
                </div>
            </div>

            <div class="form-group mb-3">
                <div class="form-check">
                    {{ form_widget(form.isActif) }}
                    {{ form_label(form.isActif) }}
                </div>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Enregistrer les modifications
                </button>
                <a href="{{ path('app_agent_show', {'id': agent.id}) }}" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Annuler
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Gérer le changement de région pour charger les brigades
    const regionSelect = document.querySelector('#{{ form.region.vars.id }}');
    const brigadeSelect = document.querySelector('#{{ form.brigade.vars.id }}');
    const currentBrigadeId = {{ agent.brigade ? agent.brigade.id : 'null' }};
    
    if (regionSelect && brigadeSelect) {
        regionSelect.addEventListener('change', function() {
            const regionId = this.value;
            
            // Vider le select des brigades
            brigadeSelect.innerHTML = '<option value="">Choisir une brigade...</option>';
            
            if (regionId) {
                // Charger les brigades via AJAX
                fetch(`/api/brigades/region/${regionId}`)
                    .then(response => response.json())
                    .then(data => {
                        data.forEach(brigade => {
                            const option = document.createElement('option');
                            option.value = brigade.id;
                            option.textContent = brigade.nom;
                            if (brigade.id == currentBrigadeId) {
                                option.selected = true;
                            }
                            brigadeSelect.appendChild(option);
                        });
                    })
                    .catch(error => console.error('Erreur:', error));
            }
        });
        
        // Déclencher le changement au chargement si une région est sélectionnée
        if (regionSelect.value) {
            regionSelect.dispatchEvent(new Event('change'));
        }
    }
});
</script>
{% endblock %}
{% endblock %}
