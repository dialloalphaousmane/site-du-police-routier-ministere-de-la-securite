{% extends 'base.html.twig' %}

{% block title %}Gestion des Agents{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestion des Agents</h1>
        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_DIRECTION_REGIONALE') or is_granted('ROLE_CHEF_BRIGADE') %}
            <a href="{{ path('app_agent_new') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> Nouvel Agent
            </a>
        {% endif %}
    </div>

    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_DIRECTION_GENERALE') %}
        <div class="row mb-3">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h5 class="card-title">Total Agents</h5>
                        <h2>{{ agents|length }}</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h5 class="card-title">Agents Actifs</h5>
                        <h2>{{ agents|filter(a => a.isActif)|length }}</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body">
                        <h5 class="card-title">Agents Inactifs</h5>
                        <h2>{{ agents|filter(a => not a.isActif)|length }}</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <a href="{{ path('app_agent_stats') }}" class="btn btn-outline-primary h-100 w-100 d-flex align-items-center justify-content-center">
                    <i class="fas fa-chart-bar"></i> Statistiques
                </a>
            </div>
        </div>
    {% endif %}

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Liste des Agents</h5>
        </div>
        <div class="card-body">
            {% if agents|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Matricule</th>
                                <th>Nom</th>
                                <th>Prénom</th>
                                <th>Grade</th>
                                <th>Région</th>
                                <th>Brigade</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for agent in agents %}
                                <tr>
                                    <td>{{ agent.matricule }}</td>
                                    <td>{{ agent.nom }}</td>
                                    <td>{{ agent.prenom }}</td>
                                    <td>{{ agent.grade }}</td>
                                    <td>{{ agent.region ? agent.region.libelle : '-' }}</td>
                                    <td>{{ agent.brigade ? agent.brigade.nom : '-' }}</td>
                                    <td>
                                        {% if agent.isActif %}
                                            <span class="badge bg-success">Actif</span>
                                        {% else %}
                                            <span class="badge bg-danger">Inactif</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="{{ path('app_agent_show', {'id': agent.id}) }}" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_DIRECTION_REGIONALE') or (is_granted('ROLE_CHEF_BRIGADE') and agent.brigade == app.user.brigade) %}
                                                <a href="{{ path('app_agent_edit', {'id': agent.id}) }}" class="btn btn-sm btn-outline-warning">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <form method="post" action="{{ path('app_agent_toggle_actif', {'id': agent.id}) }}" style="display: inline-block;">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ agent.id) }}">
                                                    <button type="submit" class="btn btn-sm {{ agent.isActif ? 'btn-outline-danger' : 'btn-outline-success' }}">
                                                        <i class="fas {{ agent.isActif ? 'fa-ban' : 'fa-check' }}"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_DIRECTION_GENERALE') or is_granted('ROLE_DIRECTION_REGIONALE') %}
                                                <form method="post" action="{{ path('app_agent_delete', {'id': agent.id}) }}" style="display: inline-block;">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ agent.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet agent ?')">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-4">
                    <i class="fas fa-users fa-3x text-muted mb-3"></i>
                    <p class="text-muted">Aucun agent trouvé</p>
                    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_DIRECTION_REGIONALE') or is_granted('ROLE_CHEF_BRIGADE') %}
                        <a href="{{ path('app_agent_new') }}" class="btn btn-primary">Créer le premier agent</a>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
