{% extends 'layout.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div class="container-fluid">
    <!-- Page Heading -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Dashboard</h1>
        <div class="btn-group">
            <a href="{{ path('app_logout') }}" class="btn btn-outline-danger">
                <i class="fas fa-sign-out-alt"></i> Déconnexion
            </a>
        </div>
    </div>

    <!-- Content Row -->
    <div class="row">
        <!-- Earnings -->
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-warning">Bienvenue sur le tableau de bord</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        Bienvenue sur le système de gestion de la police routière guinéenne. 
                        Utilisez le menu de navigation pour accéder aux différentes fonctionnalités selon votre rôle.
                    </p>
                    <div class="mt-3">
                        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                        <a href="{{ path('app_rtg_dashboard') }}" class="btn btn-primary me-2">
                            <i class="fas fa-chart-bar"></i> RTG Guinée
                        </a>
                        {% endif %}
                        
                        {% if is_granted('ROLE_DIRECTION_GENERALE') %}
                        <a href="{{ path('app_dg_accidents_dashboard') }}" class="btn btn-primary me-2">
                            <i class="fas fa-car-crash"></i> Accidents DG
                        </a>
                        <a href="{{ path('app_dg_evacuations_dashboard') }}" class="btn btn-info me-2">
                            <i class="fas fa-ambulance"></i> Évacuations DG
                        </a>
                        {% endif %}
                        
                        {% if is_granted('ROLE_DIRECTION_REGIONALE') %}
                        <a href="{{ path('app_dr_accidents_dashboard') }}" class="btn btn-primary me-2">
                            <i class="fas fa-car-crash"></i> Accidents DR
                        </a>
                        <a href="{{ path('app_dr_evacuations_dashboard') }}" class="btn btn-info me-2">
                            <i class="fas fa-ambulance"></i> Évacuations DR
                        </a>
                        {% endif %}
                        
                        {% if is_granted('ROLE_CHEF_BRIGADE') %}
                        <a href="{{ path('app_brigade_accidents_dashboard') }}" class="btn btn-primary me-2">
                            <i class="fas fa-car-crash"></i> Accidents Brigade
                        </a>
                        <a href="{{ path('app_brigade_evacuations_dashboard') }}" class="btn btn-info me-2">
                            <i class="fas fa-ambulance"></i> Évacuations Brigade
                        </a>
                        {% endif %}
                        
                        {% if is_granted('ROLE_AGENT') %}
                        <a href="{{ path('app_agent_accidents_dashboard') }}" class="btn btn-primary me-2">
                            <i class="fas fa-car-crash"></i> Mes Accidents
                        </a>
                        <a href="{{ path('app_agent_evacuations_dashboard') }}" class="btn btn-info me-2">
                            <i class="fas fa-accident"></i> Mes Évacuations
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>

        <!-- Quick Actions -->
        <div class="col-lg-6 mb-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Statistiques RTG Guinée (10 dernières années)</h6>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-4">
                            <div class="h4 mb-0 font-weight-bold text-primary">RTG Guinée</div>
                            <div class="small text-gray-500">Statistiques nationales</div>
                        </div>
                        <div class="col-4">
                            <div class="h5 mb-0 font-weight-bold text-warning">10 ans</div>
                            <div class="small text-gray-500">Période d'analyse</div>
                        </div>
                        <div class="col-4">
                            <div class="h5 mb-0 font-weight-bold text-info">Actif</div>
                            <div class="small text-gray-500">Système opérationnel</div>
                        </div>
                    </div>
                    <hr>
                    <div class="text-center">
                        <p class="mb-0">Le système RTG Guinée est maintenant opérationnel avec les statistiques des 10 dernières années.</p>
                        <p class="text-muted">Accès aux données nationales, régionales et performance.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Row -->
    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Accidents Total
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {% if app.user %}
                                    {{ app.user.accidents|length }}
                                {% else %}
                                    0
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-car-crash fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Évacuations Total
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {% if app.user %}
                                    {{ app.user.evacuations|length }}
                                {% else %}
                                    0
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-ambulance fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Rapports Total
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {% if app.user %}
                                    {{ app.user.rapports|length }}
                                {% else %}
                                    0
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-file-alt fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Brigades Total
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {% if app.user %}
                                    {{ app.user.brigades|length }}
                                {% else %}
                                    0
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-shield-alt fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Activité Récente</h6>
                </div>
                <div class="card-body">
                    <div class="timeline">
                        <div class="timeline-item">
                            <div class="timeline-marker bg-primary">
                                <i class="fas fa-play"></i>
                            </div>
                            <div class="timeline-content">
                                <h6 class="mb-1">Système initialisé</h6>
                                <p class="text-muted">Le système de gestion des accidents et évacuations est maintenant opérationnel.</p>
                                <p class="text-muted">
                                    {% if app.user %}
                                        Connecté en tant que {{ app.user.nom }} {{ app.user.prenom }}
                                    {% else %}
                                        Utilisateur non connecté
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                        
                        <div class="timeline-item">
                            <div class="timeline-marker bg-success">
                                <i class="fas fa-check"></i>
                            </div>
                            <div class="timeline-content">
                                <h6 class="mb-1">Système prêt</h6>
                                <p class="text-muted">Tous les contrôleurs et templates sont créés et prêts pour la production.</p>
                                <p class="text-muted">Le système peut maintenant être utilisé pour gérer les accidents et évacuations.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
