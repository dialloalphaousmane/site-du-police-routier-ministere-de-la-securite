{% extends 'base.html.twig' %}

{% block title %}Contrôles - Brigade {{ brigade.code }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1><i class="bi bi-list-check me-2"></i>Contrôles - {{ brigade.libelle }}</h1>
        </div>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Lieu</th>
                        <th>Type Véhicule</th>
                        <th>Immatriculation</th>
                        <th>Conducteur</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% if controls|length > 0 %}
                        {% for control in controls %}
                            <tr>
                                <td>
                                    <small>{{ control.dateControle|date('d/m/Y H:i') }}</small>
                                </td>
                                <td>{{ control.lieuControle }}</td>
                                <td>{{ control.marqueVehicule }}</td>
                                <td><strong>{{ control.immatriculation }}</strong></td>
                                <td>{{ control.prenomConducteur }} {{ control.nomConducteur }}</td>
                                <td class="text-end">
                                    <a href="{{ path('app_controle_show', {id: control.id}) }}" class="btn btn-sm btn-info" title="Voir">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="{{ path('app_controle_edit', {id: control.id}) }}" class="btn btn-sm btn-outline-secondary" title="Modifier">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="POST" action="{{ path('app_controle_delete', {id: control.id}) }}" style="display: inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ control.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Supprimer ce contrôle ?');" title="Supprimer">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Aucun contrôle</td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    {% if pagination.total_pages > 1 %}
        <nav aria-label="Pagination" class="mt-3">
            <ul class="pagination justify-content-center">
                {% if pagination.current_page > 1 %}
                    <li class="page-item">
                        <a class="page-link" href="?page={{ pagination.current_page - 1 }}">Précédent</a>
                    </li>
                {% endif %}
                {% for i in 1..pagination.total_pages %}
                    <li class="page-item {% if i == pagination.current_page %}active{% endif %}">
                        <a class="page-link" href="?page={{ i }}">{{ i }}</a>
                    </li>
                {% endfor %}
                {% if pagination.current_page < pagination.total_pages %}
                    <li class="page-item">
                        <a class="page-link" href="?page={{ pagination.current_page + 1 }}">Suivant</a>
                    </li>
                {% endif %}
            </ul>
        </nav>
    {% endif %}

    <div class="mt-3">
        <a href="{{ path('app_brigade_dashboard') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Retour
        </a>
    </div>
</div>
{% endblock %}
