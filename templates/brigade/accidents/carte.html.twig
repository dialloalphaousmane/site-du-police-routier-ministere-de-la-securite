{% extends 'base.html.twig' %}

{% block title %}Carte des Accidents - Brigade{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Carte des Accidents - {{ brigade.libelle }}</h1>
        <div class="btn-group">
            <a href="{{ path('app_brigade_accidents_liste') }}" class="btn btn-secondary">
                <i class="fas fa-list"></i> Liste
            </a>
            <a href="{{ path('app_brigade_accidents_dashboard') }}" class="btn btn-info">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Filtres</h6>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label for="period" class="form-label">Période</label>
                    <select name="period" id="period" class="form-select">
                        <option value="7" {{ period == '7' ? 'selected' : '' }}>7 jours</option>
                        <option value="30" {{ period == '30' ? 'selected' : '' }}>30 jours</option>
                        <option value="90" {{ period == '90' ? 'selected' : '' }}>3 mois</option>
                        <option value="180" {{ period == '180' ? 'selected' : '' }}>6 mois</option>
                        <option value="365" {{ period == '365' ? 'selected' : '' }}>1 an</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="gravity" class="form-label">Gravité</label>
                    <select name="gravity" id="gravity" class="form-select">
                        <option value="">Toutes</option>
                        <option value="MORTEL" {{ currentFilters.gravity == 'MORTEL' ? 'selected' : '' }}>Mortel</option>
                        <option value="GRAVE" {{ currentFilters.gravity == 'GRAVE' ? 'selected' : '' }}>Grave</option>
                        <option value="URGENT" {{ currentFilters.gravity == 'URGENT' ? 'selected' : '' }}>Urgent</option>
                        <option value="LEGER" {{ currentFilters.gravity == 'LEGER' ? 'selected' : '' }}>Léger</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-filter"></i> Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Carte</h6>
            <span class="text-muted">{{ accidents|length }} accident(s)</span>
        </div>
        <div class="card-body">
            <div id="map" style="height: 650px;"></div>
            <small class="text-muted d-block mt-2">Seuls les accidents avec latitude/longitude apparaissent.</small>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            const map = L.map('map');
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            const points = [];
            const accidents = {{ accidents|map(a => {
                id: a.id,
                reference: a.reference,
                localisation: a.localisation,
                gravite: a.gravite,
                status: a.status,
                date: a.dateAccident ? a.dateAccident|date('d/m/Y H:i') : '',
                lat: a.latitude,
                lng: a.longitude
            })|json_encode|raw }};

            accidents.forEach(a => {
                if (a.lat === null || a.lng === null) {
                    return;
                }

                points.push([a.lat, a.lng]);
                const popup = `
                    <div style="min-width:220px">
                        <div><strong>${a.reference}</strong></div>
                        <div>${a.date}</div>
                        <div>${a.localisation ?? ''}</div>
                        <div><strong>Gravité:</strong> ${a.gravite}</div>
                        <div><strong>Statut:</strong> ${a.status}</div>
                        <div class="mt-2">
                            <a href="{{ path('app_brigade_accidents_show', {'id': 0}) }}" data-id="${a.id}" class="acc-link">Ouvrir</a>
                        </div>
                    </div>
                `;

                const marker = L.marker([a.lat, a.lng]).addTo(map);
                marker.bindPopup(popup);
            });

            map.on('popupopen', function (e) {
                const link = e.popup.getElement().querySelector('.acc-link');
                if (!link) return;
                const id = link.getAttribute('data-id');
                link.setAttribute('href', '{{ path('app_brigade_accidents_show', {'id': 'ACC_ID'}) }}'.replace('ACC_ID', id));
            });

            if (points.length > 0) {
                map.fitBounds(points, {padding: [20, 20]});
            } else {
                map.setView([9.6412, -13.5784], 7);
            }
        })();
    </script>
{% endblock %}
