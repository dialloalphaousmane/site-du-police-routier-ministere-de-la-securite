{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord National - Évacuations{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Tableau de Bord National - Évacuations</h1>
        <div class="btn-group">
            <a href="{{ path('app_dg_evacuations_supervision') }}" class="btn btn-info">
                <i class="fas fa-list"></i> Supervision
            </a>
            <a href="{{ path('app_dg_evacuations_map') }}" class="btn btn-primary">
                <i class="fas fa-map"></i> Carte Nationale
            </a>
            <a href="{{ path('app_evacuations_export') }}" class="btn btn-success">
                <i class="fas fa-download"></i> Exporter
            </a>
        </div>
    </div>

    <!-- Statistiques nationales -->
    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Total National
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ totalEvacuations }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-ambulance fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                En Cours
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ evacuationsEnCours }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clock fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-danger shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                                Urgentes
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ urgentEnCours }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-exclamation-triangle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Temps Moyen
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ tempsMoyenNational }} min</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-hourglass-half fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Graphiques nationaux -->
    <div class="row">
        <div class="col-xl-8 col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">Évolution Mensuelle</h6>
                    <div class="btn-group btn-group-sm">
                        <button type="button" class="btn btn-outline-primary active" data-period="12">12 mois</button>
                        <button type="button" class="btn btn-outline-primary" data-period="6">6 mois</button>
                        <button type="button" class="btn btn-outline-primary" data-period="3">3 mois</button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="chart-area">
                        <canvas id="evolutionChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-lg-5">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Répartition par Type</h6>
                </div>
                <div class="card-body">
                    <div class="chart-pie pt-4 pb-2">
                        <canvas id="typeChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Évacuations urgentes en cours -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-danger">Évacuations Urgentes en Cours</h6>
                    <span class="badge badge-danger">{{ urgentesEnCours|length }}</span>
                </div>
                <div class="card-body">
                    {% if urgentesEnCours is not empty %}
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Référence</th>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Urgence</th>
                                    <th>Hôpital</th>
                                    <th>Région</th>
                                    <th>Brigade</th>
                                    <th>Opérateur</th>
                                    <th>Accident</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for evacuation in urgentesEnCours %}
                                <tr>
                                    <td><strong>{{ evacuation.reference }}</strong></td>
                                    <td>{{ evacuation.dateEvacuation|date('d/m/Y H:i') }}</td>
                                    <td>
                                        <span class="badge badge-{{ 
                                            evacuation.typeEvacuation == 'AMBULANCE' ? 'primary' : 
                                            (evacuation.typeEvacuation == 'HELI' ? 'info' : 'secondary') 
                                        }}">
                                            {{ evacuation.typeEvacuation }}
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge badge-danger">HAUTE</span>
                                    </td>
                                    <td>{{ evacuation.hopitalDestination }}</td>
                                    <td>{{ evacuation.region ? evacuation.region.libelle : '' }}</td>
                                    <td>{{ evacuation.brigade ? evacuation.brigade.libelle : '' }}</td>
                                    <td>{{ evacuation.createdBy ? evacuation.createdBy.nom ~ ' ' ~ evacuation.createdBy.prenom : '' }}</td>
                                    <td>
                                        {% if evacuation.accident %}
                                        <a href="{{ path('app_dg_accidents_show', {'id': evacuation.accident.id}) }}" 
                                           class="btn btn-sm btn-outline-info">
                                            {{ evacuation.accident.reference }}
                                        </a>
                                        {% else %}
                                        -
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="btn-group">
                                            <a href="{{ path('app_dg_evacuations_show', {'id': evacuation.id}) }}" 
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="{{ path('app_dg_evacuations_coordonner', {'id': evacuation.id}) }}" 
                                               class="btn btn-sm btn-outline-warning">
                                                <i class="fas fa-cogs"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-5">
                        <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                        <p class="text-muted">Aucune évacuation urgente en cours</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Performance par région -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Performance par Région</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Région</th>
                                    <th>Total</th>
                                    <th>En Cours</th>
                                    <th>Terminées</th>
                                    <th>Taux Succès</th>
                                    <th>Temps Moyen</th>
                                    <th>Performance</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for region, stats in performanceRegions %}
                                <tr>
                                    <td><strong>{{ region }}</strong></td>
                                    <td>{{ stats.total }}</td>
                                    <td>{{ stats.enCours }}</td>
                                    <td>{{ stats.terminees }}</td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-success" role="progressbar" 
                                                 style="width: {{ stats.tauxSucces }}%">
                                                {{ stats.tauxSucces }}%
                                            </div>
                                        </div>
                                    </td>
                                    <td>{{ stats.tempsMoyen|round(1) }} min</td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-{{ 
                                                stats.performance > 80 ? 'success' : 
                                                (stats.performance > 60 ? 'warning' : 'danger') 
                                            }}" role="progressbar" 
                                                 style="width: {{ stats.performance }}%">
                                                {{ stats.performance }}%
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <a href="{{ path('app_dg_evacuations_supervision') }}?region={{ region.id }}" 
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> Détails
                                        </a>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Ressources et coordination -->
    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Ressources par Brigade</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Brigade</th>
                                    <th>En Cours</th>
                                    <th>Terminées</th>
                                    <th>Taux Succès</th>
                                    <th>Opérateurs Actifs</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for brigade, stats in ressourcesBrigades %}
                                <tr>
                                    <td><strong>{{ brigade }}</strong></td>
                                    <td>{{ stats.enCours }}</td>
                                    <td>{{ stats.terminees }}</td>
                                    <td>{{ stats.tauxSucces }}%</td>
                                    <td>{{ stats.operateursActifs }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Hôpitaux les Plus Sollicités</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Hôpital</th>
                                    <th>Évacuations</th>
                                    <th>Taux d'Urgence</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for hopital, count in hopitauxFrequent %}
                                <tr>
                                    <td><strong>{{ hopital }}</strong></td>
                                    <td>{{ count }}</td>
                                    <td>{{ hopital.tauxUrgence }}%</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pics horaires et taux de résolution -->
    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Pics Horaires Nationaux</h6>
                </div>
                <div class="card-body">
                    <div class="chart-bar">
                        <canvas id="horaireChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Taux de Résolution National</h6>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-4">
                            <div class="h4 mb-0 font-weight-bold text-warning">{{ tauxResolution.EN_COURS }}</div>
                            <div class="small text-gray-500">En cours</div>
                        </div>
                        <div class="col-4">
                            <div class="h4 mb-0 font-weight-bold text-success">{{ tauxResolution.TERMINE }}</div>
                            <div class="small text-gray-500">Terminées</div>
                        </div>
                        <div class="col-4">
                            <div class="h4 mb-0 font-weight-bold text-info">{{ tauxResolution.ANNULE }}</div>
                            <div class="small text-gray-500">Annulées</div>
                        </div>
                    </div>
                    <hr>
                    <div class="text-center">
                        <div class="h5 mb-0 font-weight-bold text-primary">{{ tauxResolutionGlobal }}%</div>
                        <div class="small text-gray-500">Taux de résolution global</div>
                        <div class="progress mt-2">
                            <div class="progress-bar bg-success" role="progressbar" style="width: {{ tauxResolutionGlobal }}%">
                                {{ tauxResolutionGlobal }}%
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Données pour les graphiques
const evolutionData = {{ evolutionMensuelle|json_encode|raw }};
const typeData = {{ repartitionType|json_encode|raw }};
const horaireData = {{ picsHoraires|json_encode|raw }};
const tauxResolution = {{ tauxResolution|json_encode|raw }};

// Graphique d'évolution
const evolutionCtx = document.getElementById('evolutionChart').getContext('2d');
new Chart(evolutionCtx, {
    type: 'line',
    data: {
        labels: evolutionData.map(d => d.monthName),
        datasets: [{
            label: 'Nombre d\'évacuations',
            data: evolutionData.map(d => d.count),
            borderColor: 'rgb(54, 162, 235)',
            backgroundColor: 'rgba(54, 162, 235, 0.2)',
            tension: 0.1
        }]
    },
    options: {
        responsive: true,
        scales: {
            y: {
                beginAtZero: true
            }
        }
    }
});

// Graphique de répartition par type
const typeCtx = document.getElementById('typeChart').getContext('2d');
new Chart(typeCtx, {
    type: 'doughnut',
    data: {
        labels: Object.keys(typeData),
        datasets: [{
            data: Object.values(typeData),
            backgroundColor: ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e']
        }]
    }
});

// Graphique des pics horaires
const horaireCtx = document.getElementById('horaireChart').getContext('2d');
new Chart(horaireCtx, {
    type: 'bar',
    data: {
        labels: horaireData.map(d => d.hour + 'h'),
        datasets: [{
            label: 'Nombre d\'évacuations',
            data: horaireData.map(d => d.count),
            backgroundColor: 'rgba(54, 162, 235, 0.8)',
            borderColor: 'rgba(54, 162, 235, 1)',
            borderWidth: 1
        }]
    },
    options: {
        responsive: true,
        scales: {
            y: {
                beginAtZero: true
            }
        }
    }
});

// Gestion des périodes
document.querySelectorAll('[data-period]').forEach(button => {
    button.addEventListener('click', function() {
        document.querySelectorAll('[data-period]').forEach(btn => btn.classList.remove('active'));
        this.classList.add('active');
        // Recharger les données avec la nouvelle période
        window.location.href = '{{ path('app_dg_evacuations_dashboard') }}?period=' + this.dataset.period;
    });
});
</script>
{% endblock %}
