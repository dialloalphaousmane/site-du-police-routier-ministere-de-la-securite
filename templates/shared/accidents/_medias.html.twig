{% if accident.medias is empty %}
    <p class="text-muted mb-0">Aucune preuve ajoutée.</p>
{% else %}
    <div class="row">
        {% for media in accident.medias %}
            <div class="col-md-4 mb-3">
                <div class="border rounded p-2 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="badge badge-secondary">{{ media.type }}</span>
                        {% if is_granted('delete', media) %}
                            <form action="{{ path('app_accident_media_delete', {id: media.id}) }}" method="post" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('accident_media_delete' ~ media.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                            </form>
                        {% endif %}
                    </div>

                    <div class="mb-2">
                        {% if media.isImage %}
                            <a href="{{ media.publicPath }}" target="_blank">
                                <img src="{{ media.publicPath }}" alt="{{ media.originalName }}" class="img-fluid rounded" />
                            </a>
                        {% else %}
                            <a href="{{ media.publicPath }}" target="_blank" class="btn btn-outline-secondary btn-sm">
                                <i class="fas fa-file"></i> Ouvrir
                            </a>
                        {% endif %}
                    </div>

                    <div class="small text-muted">
                        <div><strong>{{ media.originalName }}</strong></div>
                        <div>{{ media.createdAt|date('d/m/Y H:i') }}</div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
