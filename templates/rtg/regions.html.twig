{% extends 'layout.html.twig' %}

{% block title %}RTG Guinée - Régions{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">RTG Guinée - Régions</h1>
        <div class="btn-group">
            <a href="{{ path('app_rtg_dashboard') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Retour Dashboard
            </a>
            <a href="{{ path('app_rtg_evolution') }}" class="btn btn-primary">
                <i class="fas fa-chart-line"></i> Évolution
            </a>
            <a href="{{ path('app_rtg_performance') }}" class="btn btn-warning">
                <i class="fas fa-tachometer-alt"></i> Performance
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Indicateurs par Région (10 dernières années)</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Région</th>
                                    <th>Accidents</th>
                                    <th>Évacuations</th>
                                    <th>Victimes</th>
                                    <th>Véhicules</th>
                                    <th>Temps moyen (min)</th>
                                    <th>Performance</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for region in regionalPerformance %}
                                    <tr>
                                        <td><strong>{{ region.region }}</strong></td>
                                        <td>{{ region.total_accidents }}</td>
                                        <td>{{ region.total_evacuations }}</td>
                                        <td>{{ region.total_victimes }}</td>
                                        <td>{{ region.total_vehicules }}</td>
                                        <td>{{ region.temps_moyen_traitement }}</td>
                                        <td>{{ region.performance|round(1) }}%</td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="7" class="text-center text-muted">Aucune donnée disponible.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Évolution Nationale (Accidents / mois)</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Mois</th>
                                    <th>Accidents</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in nationalEvolution %}
                                    <tr>
                                        <td>{{ row.month }}</td>
                                        <td>{{ row.count }}</td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="2" class="text-center text-muted">Aucune donnée disponible.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Statistiques Mensuelles (Accidents + Évacuations)</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Mois</th>
                                    <th>Accidents</th>
                                    <th>Évacuations</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in monthlyStats %}
                                    <tr>
                                        <td>{{ row.date }}</td>
                                        <td>{{ row.accidents_count }}</td>
                                        <td>{{ row.evacuations_count }}</td>
                                        <td><strong>{{ row.total }}</strong></td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="text-center text-muted">Aucune donnée disponible.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
