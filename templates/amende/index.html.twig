{% extends 'base.html.twig' %}

{% block title %}Liste des Amendes - Police Routière{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <h1>
                    <i class="bi bi-cash-stack"></i> Amendes Routières
                </h1>
                {% if is_granted('ROLE_AGENT') %}
                    <a href="{{ path('app_amende_new') }}" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Nouvelle Amende
                    </a>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Cartes de statistiques -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Amendes</h5>
                    <h2>{{ amendes|length }}</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5 class="card-title">En Attente</h5>
                    <h2>{{ amendes|filter(a => a.statut == 'EN_ATTENTE')|length }}</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Payées</h5>
                    <h2>{{ amendes|filter(a => a.statut == 'PAYEE')|length }}</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h5 class="card-title">Rejetées</h5>
                    <h2>{{ amendes|filter(a => a.statut == 'REJETEE')|length }}</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Tableau des amendes -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-list"></i> Liste des Amendes
            </h5>
        </div>
        <div class="card-body">
            {% if amendes|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Référence</th>
                                <th>Infraction</th>
                                <th>Conducteur</th>
                                <th>Montant Total</th>
                                <th>Montant Payé</th>
                                <th>Statut</th>
                                <th>Date Émission</th>
                                <th>Date Échéance</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for amende in amendes %}
                                <tr>
                                    <td>
                                        <span class="badge bg-primary">{{ amende.reference }}</span>
                                    </td>
                                    <td>
                                        <a href="{{ path('app_infraction_show', {'id': amende.infraction.id}) }}" 
                                           class="text-decoration-none">
                                            <span class="badge bg-warning">{{ amende.infraction.codeInfraction }}</span>
                                        </a>
                                    </td>
                                    <td>
                                        {{ amende.infraction.controle.nomConducteur }} {{ amende.infraction.controle.prenomConducteur }}
                                    </td>
                                    <td>
                                        <strong class="text-primary">{{ amende.montantTotal|number_format(0, ',', ' ') }} GNF</strong>
                                    </td>
                                    <td>
                                        <strong class="text-success">{{ amende.montantPaye|number_format(0, ',', ' ') }} GNF</strong>
                                    </td>
                                    <td>
                                        {% if amende.statut == 'EN_ATTENTE' %}
                                            <span class="badge bg-warning">En Attente</span>
                                        {% elseif amende.statut == 'PAYEE' %}
                                            <span class="badge bg-success">Payée</span>
                                        {% elseif amende.statut == 'REJETEE' %}
                                            <span class="badge bg-danger">Rejetée</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {{ amende.dateEmission ? amende.dateEmission|date('d/m/Y') : 'N/A' }}
                                    </td>
                                    <td>
                                        {{ amende.dateEcheance ? amende.dateEcheance|date('d/m/Y') : 'N/A' }}
                                        {% if amende.dateEcheance and amende.dateEcheance < date() %}
                                            <i class="bi bi-exclamation-triangle text-danger" title="En retard"></i>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="{{ path('app_amende_show', {'id': amende.id}) }}" 
                                               class="btn btn-sm btn-outline-primary" title="Voir">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            {% if is_granted('ROLE_AGENT') %}
                                                <a href="{{ path('app_amende_edit', {'id': amende.id}) }}" 
                                                   class="btn btn-sm btn-outline-warning" title="Modifier">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                            {% endif %}
                                            <a href="{{ path('app_amende_recu', {'id': amende.id}) }}" 
                                               class="btn btn-sm btn-outline-success" title="Reçu">
                                                <i class="bi bi-receipt"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-4">
                    <i class="bi bi-cash-stack display-1 text-muted"></i>
                    <h4 class="mt-3">Aucune amende trouvée</h4>
                    <p class="text-muted">
                        {% if is_granted('ROLE_AGENT') %}
                            Commencez par <a href="{{ path('app_infraction_new') }}">créer une infraction</a> puis générez des amendes.
                        {% endif %}
                    </p>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
